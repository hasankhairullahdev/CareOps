{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/careops"
  },
  "Urls": "http://+:5000",
  "ReverseProxy": {
    "Routes": {
      "patients-route": {
        "ClusterId": "patient-service",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/patients/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/patients/{**catch-all}" }
        ]
      },
      "blood-types-route": {
        "ClusterId": "patient-service",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/blood-types/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/blood-types/{**catch-all}" }
        ]
      },
      "allergy-types-route": {
        "ClusterId": "patient-service",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/allergy-types/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/allergy-types/{**catch-all}" }
        ]
      },
      "appointments-route": {
        "ClusterId": "appointment-service",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/appointments/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/appointments/{**catch-all}" }
        ]
      },
      "doctors-route": {
        "ClusterId": "appointment-service",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/doctors/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/doctors/{**catch-all}" }
        ]
      },
      "pharmacy-suppliers-route": {
        "ClusterId": "pharmacy-service",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/pharmacy/suppliers/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/pharmacy/suppliers/{**catch-all}" }
        ]
      },
      "pharmacy-route": {
        "ClusterId": "pharmacy-service",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/pharmacy/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/pharmacy/{**catch-all}" }
        ]
      },
      "billing-payment-methods-route": {
        "ClusterId": "billing-service",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/billing/payment-methods/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/billing/payment-methods/{**catch-all}" }
        ]
      },
      "billing-tariffs-route": {
        "ClusterId": "billing-service",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/billing/tariffs/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/billing/tariffs/{**catch-all}" }
        ]
      },
      "billing-route": {
        "ClusterId": "billing-service",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/billing/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/billing/{**catch-all}" }
        ]
      },
      "notifications-route": {
        "ClusterId": "notification-service",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/notifications/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "patient-service": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5001/"
          }
        }
      },
      "appointment-service": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5002/"
          }
        }
      },
      "pharmacy-service": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5003/"
          }
        }
      },
      "billing-service": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5004/"
          }
        }
      },
      "notification-service": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5005/"
          }
        }
      }
    }
  }
}
